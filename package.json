{
  "name": "mood",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "."
  ],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "next dev",
    "prebuild": "DATABASE_URL=${DATABASE_URL:-postgresql://mood_user:password@localhost:5432/mood_db} PRISMA_CLI_BINARY_TARGETS=${PRISMA_CLI_BINARY_TARGETS:-linux-musl-openssl-3.0.x} PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=${PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING:-1} bunx prisma generate",
    "build": "./scripts/build-with-auth-env.sh",
    "start": "next start",
    "lint": "eslint . --max-warnings=10",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check:lines": "bun run ./scripts/check-lines.ts",
    "knip": "DATABASE_URL=${DATABASE_URL:-postgresql://mood_user:password@localhost:5432/mood_db} knip",
    "sherif": "sherif -r root-package-dependencies"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-three/fiber": "9.6.0",
    "@tanstack/react-query": "5.99.0",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "11.16.0",
    "better-auth": "1.6.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "12.38.0",
    "lucide-react": "1.8.0",
    "nanoid": "5.1.9",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "pg": "8.20.0",
    "prisma": "7.7.0",
    "react": "19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "recharts": "3.8.1",
    "redis": "^5.12.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "3.5.0",
    "three": "0.183.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@eslint/js": "9.39.4",
    "@next/eslint-plugin-next": "16.2.4",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.7",
    "@types/three": "0.183.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "knip": "^6.3.1",
    "postcss": "8.5.10",
    "sherif": "^1.11.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "lodash": "4.17.23",
    "hono": "4.11.7"
  }
}
